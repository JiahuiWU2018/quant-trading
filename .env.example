# ============================================================
# quant-trading — environment variable template
# ============================================================
# Copy this file to .env (never commit .env) and fill in values.
# The private strategy repository may extend this with its own vars.
# ============================================================

# --- Cache ---
# Directory for local parquet cache files (default: ~/.cache/quant_trading)
QUANT_CACHE_DIR=

# Cache TTL in hours (default: 24)
QUANT_CACHE_TTL_HOURS=24

# --- Data APIs (Phase 1: yfinance needs no key) ---
# Alpha Vantage (Phase 6)
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY_HERE

# Finnhub (Phase 6)
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE

# --- Interactive Brokers (Phase 3) ---
# IB Gateway or TWS host (default: 127.0.0.1)
IB_HOST=127.0.0.1

# IB Gateway paper trading port: 7497
# IB Gateway live trading port:  4001
# TWS paper trading port:        7497
# TWS live trading port:         7496
IB_PORT=7497

# IB client ID — must be unique per connected application
IB_CLIENT_ID=1

# --- Execution Safety (Phase 3) ---
# Set to "true" to log orders without submitting (default: true — opt-out required)
DRY_RUN=true

# Maximum notional value per order in account currency
MAX_ORDER_NOTIONAL=

# Maximum number of open positions
MAX_POSITIONS=
